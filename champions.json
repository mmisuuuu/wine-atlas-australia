{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Each Grape Has Its Champions",
    "subtitle": [
      "Top 5 regions for each of the five most-reviewed Australian grape varieties, ranked by average expert score.",
      "Aggregated live from individual reviews; region-variety pairs with at least 5 reviews only."
    ],
    "fontSize": 16,
    "subtitleFontSize": 11,
    "subtitleColor": "#666",
    "anchor": "start"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/mmisuuuu/wine-atlas-australia/main/wine_reviews.csv"
  },
  "transform": [
    {"filter": "datum.variety == 'Shiraz' || datum.variety == 'Chardonnay' || datum.variety == 'Cabernet Sauvignon' || datum.variety == 'Riesling' || datum.variety == 'Pinot Noir'"},
    {"filter": "datum.region_1 != null && datum.points != null"},
    {
      "aggregate": [
        {"op": "mean", "field": "points", "as": "avg_score"},
        {"op": "count", "field": "points", "as": "n_reviews"},
        {"op": "mean", "field": "price", "as": "avg_price"}
      ],
      "groupby": ["variety", "region_1"]
    },
    {"filter": "datum.n_reviews >= 5"},
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "avg_score", "order": "descending"}],
      "groupby": ["variety"]
    },
    {"filter": "datum.rank <= 5"}
  ],
  "config": {"concat": {"spacing": 18}},
  "vconcat": [
    {
      "title": {"text": "Shiraz", "anchor": "start", "fontSize": 14, "color": "#7b1d3a"},
      "transform": [{"filter": "datum.variety == 'Shiraz'"}],
      "width": 500, "height": 110,
      "mark": {"type": "bar", "color": "#7b1d3a", "cornerRadiusEnd": 3, "stroke": "white", "strokeWidth": 1},
      "encoding": {
        "y": {"field": "region_1", "type": "nominal", "sort": "-x", "title": null, "axis": {"labelFontSize": 11, "labelLimit": 150}},
        "x": {"field": "avg_score", "type": "quantitative", "scale": {"domain": [85, 92]}, "title": null, "axis": {"labelFontSize": 9, "grid": true, "gridOpacity": 0.25, "tickCount": 6}},
        "tooltip": [
          {"field": "region_1", "type": "nominal", "title": "Region"},
          {"field": "avg_score", "type": "quantitative", "title": "Avg Score", "format": ".2f"},
          {"field": "n_reviews", "type": "quantitative", "title": "Reviews"},
          {"field": "avg_price", "type": "quantitative", "title": "Avg Price (USD)", "format": "$.0f"}
        ]
      }
    },
    {
      "title": {"text": "Chardonnay", "anchor": "start", "fontSize": 14, "color": "#a08742"},
      "transform": [{"filter": "datum.variety == 'Chardonnay'"}],
      "width": 500, "height": 110,
      "mark": {"type": "bar", "color": "#c9a961", "cornerRadiusEnd": 3, "stroke": "white", "strokeWidth": 1},
      "encoding": {
        "y": {"field": "region_1", "type": "nominal", "sort": "-x", "title": null, "axis": {"labelFontSize": 11, "labelLimit": 150}},
        "x": {"field": "avg_score", "type": "quantitative", "scale": {"domain": [85, 92]}, "title": null, "axis": {"labelFontSize": 9, "grid": true, "gridOpacity": 0.25, "tickCount": 6}},
        "tooltip": [
          {"field": "region_1", "type": "nominal", "title": "Region"},
          {"field": "avg_score", "type": "quantitative", "title": "Avg Score", "format": ".2f"},
          {"field": "n_reviews", "type": "quantitative", "title": "Reviews"},
          {"field": "avg_price", "type": "quantitative", "title": "Avg Price (USD)", "format": "$.0f"}
        ]
      }
    },
    {
      "title": {"text": "Cabernet Sauvignon", "anchor": "start", "fontSize": 14, "color": "#5d4e75"},
      "transform": [{"filter": "datum.variety == 'Cabernet Sauvignon'"}],
      "width": 500, "height": 110,
      "mark": {"type": "bar", "color": "#5d4e75", "cornerRadiusEnd": 3, "stroke": "white", "strokeWidth": 1},
      "encoding": {
        "y": {"field": "region_1", "type": "nominal", "sort": "-x", "title": null, "axis": {"labelFontSize": 11, "labelLimit": 150}},
        "x": {"field": "avg_score", "type": "quantitative", "scale": {"domain": [85, 92]}, "title": null, "axis": {"labelFontSize": 9, "grid": true, "gridOpacity": 0.25, "tickCount": 6}},
        "tooltip": [
          {"field": "region_1", "type": "nominal", "title": "Region"},
          {"field": "avg_score", "type": "quantitative", "title": "Avg Score", "format": ".2f"},
          {"field": "n_reviews", "type": "quantitative", "title": "Reviews"},
          {"field": "avg_price", "type": "quantitative", "title": "Avg Price (USD)", "format": "$.0f"}
        ]
      }
    },
    {
      "title": {"text": "Riesling", "anchor": "start", "fontSize": 14, "color": "#3a7d44"},
      "transform": [{"filter": "datum.variety == 'Riesling'"}],
      "width": 500, "height": 110,
      "mark": {"type": "bar", "color": "#3a7d44", "cornerRadiusEnd": 3, "stroke": "white", "strokeWidth": 1},
      "encoding": {
        "y": {"field": "region_1", "type": "nominal", "sort": "-x", "title": null, "axis": {"labelFontSize": 11, "labelLimit": 150}},
        "x": {"field": "avg_score", "type": "quantitative", "scale": {"domain": [85, 92]}, "title": null, "axis": {"labelFontSize": 9, "grid": true, "gridOpacity": 0.25, "tickCount": 6}},
        "tooltip": [
          {"field": "region_1", "type": "nominal", "title": "Region"},
          {"field": "avg_score", "type": "quantitative", "title": "Avg Score", "format": ".2f"},
          {"field": "n_reviews", "type": "quantitative", "title": "Reviews"},
          {"field": "avg_price", "type": "quantitative", "title": "Avg Price (USD)", "format": "$.0f"}
        ]
      }
    },
    {
      "title": {"text": "Pinot Noir", "anchor": "start", "fontSize": 14, "color": "#c44569"},
      "transform": [{"filter": "datum.variety == 'Pinot Noir'"}],
      "width": 500, "height": 110,
      "mark": {"type": "bar", "color": "#c44569", "cornerRadiusEnd": 3, "stroke": "white", "strokeWidth": 1},
      "encoding": {
        "y": {"field": "region_1", "type": "nominal", "sort": "-x", "title": null, "axis": {"labelFontSize": 11, "labelLimit": 150}},
        "x": {"field": "avg_score", "type": "quantitative", "scale": {"domain": [85, 92]}, "title": "Avg Score", "axis": {"labelFontSize": 9, "grid": true, "gridOpacity": 0.25, "tickCount": 6}},
        "tooltip": [
          {"field": "region_1", "type": "nominal", "title": "Region"},
          {"field": "avg_score", "type": "quantitative", "title": "Avg Score", "format": ".2f"},
          {"field": "n_reviews", "type": "quantitative", "title": "Reviews"},
          {"field": "avg_price", "type": "quantitative", "title": "Avg Price (USD)", "format": "$.0f"}
        ]
      }
    }
  ],
  "resolve": {"scale": {"y": "independent"}}
}
