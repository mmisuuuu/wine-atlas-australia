{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Each Grape Has Its Champions",
    "subtitle": [
      "Top 5 regions for each of the five most-reviewed Australian grape varieties, ranked by average expert score.",
      "Aggregated from individual reviews; region-variety pairs with at least 5 reviews only."
    ],
    "fontSize": 16,
    "subtitleFontSize": 11,
    "subtitleColor": "#666",
    "anchor": "start"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/mmisuuuu/wine-atlas-australia/main/wine_reviews.csv"
  },
  "transform": [
    {"filter": "datum.variety == 'Shiraz' || datum.variety == 'Chardonnay' || datum.variety == 'Cabernet Sauvignon' || datum.variety == 'Riesling' || datum.variety == 'Pinot Noir'"},
    {"filter": "datum.region_1 != null && datum.points != null"},
    {
      "aggregate": [
        {"op": "mean", "field": "points", "as": "avg_score"},
        {"op": "count", "field": "points", "as": "n_reviews"},
        {"op": "mean", "field": "price", "as": "avg_price"}
      ],
      "groupby": ["variety", "region_1"]
    },
    {"filter": "datum.n_reviews >= 5"},
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "avg_score", "order": "descending"}],
      "groupby": ["variety"]
    },
    {"filter": "datum.rank <= 5"}
  ],
  "facet": {
    "field": "variety",
    "type": "nominal",
    "columns": 3,
    "title": null,
    "header": {
      "labelFontSize": 13,
      "labelFontWeight": "bold",
      "labelColor": "#3A2A30",
      "labelAnchor": "start",
      "labelPadding": 6
    },
    "sort": ["Shiraz", "Chardonnay", "Cabernet Sauvignon", "Riesling", "Pinot Noir"]
  },
  "spec": {
    "width": 180,
    "height": 120,
    "mark": {"type": "bar", "cornerRadiusEnd": 3, "stroke": "white", "strokeWidth": 1},
    "encoding": {
      "y": {
        "field": "region_1",
        "type": "nominal",
        "sort": "-x",
        "title": null,
        "axis": {"labelFontSize": 10, "labelLimit": 130}
      },
      "x": {
        "field": "avg_score",
        "type": "quantitative",
        "scale": {"domain": [85, 92]},
        "title": "Avg Score",
        "axis": {"labelFontSize": 9, "titleFontSize": 10, "grid": true, "gridOpacity": 0.25, "tickCount": 4}
      },
      "color": {
        "field": "variety",
        "type": "nominal",
        "scale": {
          "domain": ["Shiraz", "Chardonnay", "Cabernet Sauvignon", "Riesling", "Pinot Noir"],
          "range": ["#7b1d3a", "#c9a961", "#5d4e75", "#3a7d44", "#c44569"]
        },
        "legend": null
      },
      "tooltip": [
        {"field": "region_1", "type": "nominal", "title": "Region"},
        {"field": "variety", "type": "nominal", "title": "Variety"},
        {"field": "avg_score", "type": "quantitative", "title": "Avg Score", "format": ".2f"},
        {"field": "n_reviews", "type": "quantitative", "title": "Reviews"},
        {"field": "avg_price", "type": "quantitative", "title": "Avg Price (USD)", "format": "$.0f"}
      ]
    }
  }
}
