{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Each Grape Has Its Champions",
    "subtitle": [
      "For each major variety, the top 5 regions by average expert score.",
      "Hover any dot for region, score, review count and price. The leftmost dot in each row is the variety's #1 region."
    ],
    "fontSize": 16,
    "subtitleFontSize": 11,
    "subtitleColor": "#666",
    "anchor": "start"
  },
  "width": 560,
  "height": 240,
  "data": {
    "url": "https://raw.githubusercontent.com/mmisuuuu/wine-atlas-australia/main/wine_reviews.csv"
  },
  "transform": [
    {"filter": "datum.variety == 'Shiraz' || datum.variety == 'Chardonnay' || datum.variety == 'Cabernet Sauvignon' || datum.variety == 'Riesling' || datum.variety == 'Pinot Noir'"},
    {"filter": "datum.region_1 != null && datum.points != null"},
    {
      "aggregate": [
        {"op": "mean", "field": "points", "as": "avg_score"},
        {"op": "count", "field": "points", "as": "n_reviews"},
        {"op": "mean", "field": "price", "as": "avg_price"}
      ],
      "groupby": ["variety", "region_1"]
    },
    {"filter": "datum.n_reviews >= 5"},
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "avg_score", "order": "descending"}],
      "groupby": ["variety"]
    },
    {"filter": "datum.rank <= 5"}
  ],
  "encoding": {
    "y": {
      "field": "variety",
      "type": "nominal",
      "title": null,
      "sort": ["Shiraz", "Chardonnay", "Cabernet Sauvignon", "Riesling", "Pinot Noir"],
      "axis": {"labelFontSize": 12, "labelFontWeight": "bold", "domain": false, "ticks": false, "labelPadding": 8}
    },
    "x": {
      "field": "avg_score",
      "type": "quantitative",
      "title": "Average Reviewer Score",
      "scale": {"domain": [85, 92]},
      "axis": {"grid": true, "gridOpacity": 0.25}
    }
  },
  "layer": [
    {
      "mark": {"type": "circle", "size": 240, "opacity": 0.85, "stroke": "white", "strokeWidth": 1.5},
      "encoding": {
        "color": {
          "field": "variety",
          "type": "nominal",
          "scale": {
            "domain": ["Shiraz", "Chardonnay", "Cabernet Sauvignon", "Riesling", "Pinot Noir"],
            "range": ["#7b1d3a", "#c9a961", "#5d4e75", "#3a7d44", "#c44569"]
          },
          "legend": null
        },
        "tooltip": [
          {"field": "variety", "type": "nominal", "title": "Variety"},
          {"field": "region_1", "type": "nominal", "title": "Region"},
          {"field": "rank", "type": "quantitative", "title": "Rank within variety"},
          {"field": "avg_score", "type": "quantitative", "title": "Avg Score", "format": ".2f"},
          {"field": "n_reviews", "type": "quantitative", "title": "Reviews"},
          {"field": "avg_price", "type": "quantitative", "title": "Avg Price (USD)", "format": "$.0f"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.rank == 1"}],
      "mark": {"type": "text", "align": "left", "dx": 12, "fontSize": 10, "fontWeight": "bold", "color": "#3A2A30"},
      "encoding": {
        "text": {"field": "region_1"}
      }
    }
  ]
}
