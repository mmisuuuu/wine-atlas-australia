{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Does Price Predict Quality?",
    "subtitle": "Each dot is an Australian wine, plotted by price and reviewer score",
    "fontSize": 16,
    "anchor": "start"
  },
  "width": 600,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/mmisuuuu/wine-atlas-australia/main/wine_reviews.csv"
  },
  "transform": [
    {"filter": "datum.price != null && datum.points != null"},
    {"calculate": "indexof(['Shiraz', 'Chardonnay', 'Cabernet Sauvignon', 'Riesling', 'Pinot Noir'], datum.variety) >= 0 ? datum.variety : 'Other'", "as": "variety_grouped"}
  ],
  "encoding": {
    "x": {"field": "price", "type": "quantitative", "scale": {"type": "log"}, "title": "Price (USD, log scale)", "axis": {"format": "$,d"}},
    "y": {"field": "points", "type": "quantitative", "scale": {"domain": [78, 100]}, "title": "Reviewer Score (points)"}
  },
  "layer": [
    {
      "mark": {"type": "circle", "opacity": 0.6, "size": 60},
      "encoding": {
        "color": {"field": "variety_grouped", "type": "nominal", "title": "Variety", "scale": {"scheme": "category10"}},
        "tooltip": [
          {"field": "title", "type": "nominal", "title": "Wine"},
          {"field": "winery", "type": "nominal", "title": "Winery"},
          {"field": "variety", "type": "nominal", "title": "Variety"},
          {"field": "region_1", "type": "nominal", "title": "Region"},
          {"field": "price", "type": "quantitative", "title": "Price", "format": "$,.0f"},
          {"field": "points", "type": "quantitative", "title": "Score"}
        ]
      }
    },
    {
      "data": {"values": [{"x": 1.6, "y": 97.5}]},
      "mark": {"type": "text", "align": "left", "fontSize": 12, "fontWeight": "bold", "color": "#2a7d44", "lineHeight": 14},
      "encoding": {
        "x": {"field": "x", "type": "quantitative"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"value": ["Best value lives here:", "high score, low price"]}
      }
    },
    {
      "data": {"values": [{"x1": 2.0, "y1": 96.6, "x2": 11, "y2": 93.2}]},
      "mark": {"type": "rule", "color": "#2a7d44", "strokeWidth": 1.5},
      "encoding": {
        "x": {"field": "x1", "type": "quantitative"},
        "y": {"field": "y1", "type": "quantitative"},
        "x2": {"field": "x2"},
        "y2": {"field": "y2"}
      }
    }
  ]
}
