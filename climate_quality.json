{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Climate, Quality, and Scale",
    "subtitle": "Each circle is a wine region; size = 2024 crush volume",
    "fontSize": 16,
    "anchor": "start"
  },
  "width": 600,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/mmisuuuu/wine-atlas-australia/main/wine_regions_with_ratings.csv"
  },
  "transform": [
    {"filter": "datum.avg_points != null"},
    {"filter": "datum.growing_degree_days != null"}
  ],
  "mark": {
    "type": "circle",
    "opacity": 0.7,
    "stroke": "white",
    "strokeWidth": 1
  },
  "encoding": {
    "x": {
      "field": "growing_degree_days",
      "type": "quantitative",
      "title": "Growing Degree Days (warmer →)",
      "scale": {"zero": false}
    },
    "y": {
      "field": "avg_points",
      "type": "quantitative",
      "title": "Average Reviewer Score",
      "scale": {"zero": false}
    },
    "size": {
      "field": "crush_2024",
      "type": "quantitative",
      "scale": {"range": [40, 400]},
      "legend": null
    },
    "color": {
      "field": "state",
      "type": "nominal",
      "title": "State",
      "scale": {"scheme": "tableau10"}
    },
    "tooltip": [
      {"field": "region", "type": "nominal", "title": "Region"},
      {"field": "state", "type": "nominal", "title": "State"},
      {"field": "avg_points", "type": "quantitative", "title": "Avg Score", "format": ".1f"},
      {"field": "crush_2024", "type": "quantitative", "title": "Crush (tonnes)", "format": ","}
    ]
  }
}
