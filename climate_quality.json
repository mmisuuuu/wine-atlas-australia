{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Climate, Quality, and Scale",
    "subtitle": "Each circle is a wine region; size = 2024 crush, x = warmth, y = avg rating",
    "fontSize": 16,
    "anchor": "start"
  },
  "width": 600,
  "height": 380,
  "autosize": {"type": "pad", "contains": "padding"},
  "data": {
    "url": "https://raw.githubusercontent.com/mmisuuuu/wine-atlas-australia/main/wine_regions_with_ratings.csv"
  },
  "transform": [
    {"filter": "datum.avg_points != null && datum.growing_degree_days != null"}
  ],
  "mark": {"type": "circle", "opacity": 0.7, "stroke": "white", "strokeWidth": 1},
  "encoding": {
    "x": {
      "field": "growing_degree_days",
      "type": "quantitative",
      "title": "Growing Degree Days (warmer →)",
      "scale": {"zero": false}
    },
    "y": {
      "field": "avg_points",
      "type": "quantitative",
      "title": "Average Reviewer Score",
      "scale": {"zero": false}
    },
    "size": {
      "field": "crush_2024",
      "type": "quantitative",
      "title": "2024 Crush",
      "scale": {"range": [30, 400]},
      "legend": {"format": ".0s", "orient": "right"}
    },
    "color": {
      "field": "state",
      "type": "nominal",
      "title": "State",
      "scale": {"scheme": "tableau10"},
      "legend": {"orient": "right"}
    },
    "tooltip": [
      {"field": "region", "type": "nominal", "title": "Region"},
      {"field": "state", "type": "nominal", "title": "State"},
      {"field": "growing_degree_days", "type": "quantitative", "title": "Growing Degree Days"},
      {"field": "avg_points", "type": "quantitative", "title": "Avg Score", "format": ".1f"},
      {"field": "crush_2024", "type": "quantitative", "title": "2024 Crush (tonnes)", "format": ","},
      {"field": "review_count", "type": "quantitative", "title": "Reviews"}
    ]
  }
}
